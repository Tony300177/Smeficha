# ============================================================
# Configuração do Banco de Dados MySQL (XAMPP)
# Altere DB_HOST para o IP do computador onde o XAMPP está rodando
# se o backend rodar em máquina diferente do banco.
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sme_ficai

# ============================================================
# Servidor da API
# SERVER_HOST=0.0.0.0 permite conexões de qualquer IP externo
# ============================================================
SERVER_PORT=5174
SERVER_HOST=0.0.0.0

# ============================================================
# CORS — deixe em branco ou remova para aceitar qualquer origem
# (necessário para escolas acessarem de IPs externos)
# ============================================================
# CORS_ORIGINS=
